[importlinter]
root_packages =
    scop

# ─────────────────────────────────────────────────────────────────────────────
# Each contract below enforces one row of the edge contract table.
# cli.py is excluded from import-linter: boundary enforced at symbol level by ast-grep.
# Symbol-level rules (AppDispatcher only, argparse, sys.exit) are enforced
# by ast-grep — import-linter handles layer-level direct imports only.
# ─────────────────────────────────────────────────────────────────────────────


# bases.py — stdlib-only leaf; all layers may import from it.
[importlinter:contract:bases]
name = Bases depend on nothing internal
type = forbidden
source_modules =
    scop.bases
forbidden_modules =
    scop.models
    scop.ports
    scop.services
    scop.adapters
    scop.app
    scop.cli
    scop.utils


# cli.py — edge verb: dispatches
# cli.py may only depend on app.dispatcher from internal modules.
[importlinter:contract:cli]
name = CLI may only import AppDispatcher module
type = forbidden
source_modules =
    scop.cli
forbidden_modules =
    scop.adapters
    scop.services
    scop.models
    scop.ports
    scop.utils
    scop.app
ignore_imports =
    scop.cli -> scop.app.dispatcher


# app/ — edge verbs: wires, types
# app/ is the composition root — it may import services, adapters, and ports.
# It may not import cli or utils.
[importlinter:contract:app]
name = App may not import CLI or utils
type = forbidden
source_modules =
    scop.app
forbidden_modules =
    scop.cli
    scop.utils


# services/ — edge verbs: calls (ports), reads (models)
# The DI rule: services may not import adapters directly.
# They call adapters through ports — import-linter enforces the boundary.
[importlinter:contract:services]
name = Services may not import adapters directly
type = forbidden
source_modules =
    scop.services
forbidden_modules =
    scop.adapters
    scop.app
    scop.cli
    scop.utils


# adapters/ — edge verbs: implements (ports), reads (models), uses (utils)
# Adapters may not reach up into services, app, or cli.
[importlinter:contract:adapters]
name = Adapters may not reach up into services, app, or CLI
type = forbidden
source_modules =
    scop.adapters
forbidden_modules =
    scop.services
    scop.app
    scop.cli


# ports/ — edge verb: types (models)
# Ports may only reference models. No other internal imports permitted.
[importlinter:contract:ports]
name = Ports may only reference models
type = forbidden
source_modules =
    scop.ports
forbidden_modules =
    scop.services
    scop.adapters
    scop.app
    scop.cli
    scop.utils


# models/ — no edge out
# models/ is the innermost layer. It depends on nothing internal.
[importlinter:contract:models]
name = Models depend on nothing internal
type = forbidden
source_modules =
    scop.models
forbidden_modules =
    scop.ports
    scop.services
    scop.adapters
    scop.app
    scop.cli
    scop.utils


# utils/ — no edge out
# utils/ is the mechanism layer. It depends on nothing internal.
# Third-party imports are permitted (enforced separately by ast-grep Rule 1).
[importlinter:contract:utils]
name = Utils depend on nothing internal
type = forbidden
source_modules =
    scop.utils
forbidden_modules =
    scop.models
    scop.ports
    scop.services
    scop.adapters
    scop.app
    scop.cli
