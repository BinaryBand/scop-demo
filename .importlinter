[importlinter]
root_packages =
    scop

# ─────────────────────────────────────────────────────────────────────────────
# Each contract below enforces one row of the edge contract table.
# Symbol-level rules (AppDispatcher only, argparse, sys.exit) are enforced
# by ast-grep — import-linter handles layer-level direct imports only.
# ─────────────────────────────────────────────────────────────────────────────


# cli.py — edge verb: dispatches
# Forbids cli from reaching past app/ into any other layer.
# Symbol-level enforcement (AppDispatcher only) is handled by ast-grep.
[importlinter:contract:cli]
name = CLI may only import app
type = forbidden
source_modules =
    scop.cli
forbidden_modules =
    scop.adapters
    scop.services
    scop.ports
    scop.utils
ignore_imports =
    scop.app -> scop.models.bases
    scop.app.dispatcher -> scop.models.bases
    scop.app.stream -> scop.models.messages
    scop.app.stream -> scop.models.results
    scop.app.registry.snap_app -> scop.adapters.snapshot_adapter
    scop.app.registry.snap_app -> scop.models.bases
    scop.app.registry.snap_app -> scop.models.messages
    scop.app.registry.snap_app -> scop.services.create_snapshot_service
    scop.app.registry.snap_app -> scop.services.diff_snapshots_service
    scop.app.registry.snap_app -> scop.services.list_snapshots_service
    scop.app.registry.snap_app -> scop.services.snapshot_status_service
    scop.app.registry.root_app -> scop.models.bases
    scop.app.registry.root_app -> scop.models.messages
    scop.app.registry.diff_app -> scop.models.bases
    scop.app.registry.diff_app -> scop.models.messages
    scop.app.registry.log_app -> scop.models.bases
    scop.app.registry.log_app -> scop.models.messages
    scop.app.registry.restore_app -> scop.models.bases
    scop.app.registry.restore_app -> scop.models.messages
    scop.app.registry.status_app -> scop.models.bases
    scop.app.registry.status_app -> scop.models.messages


# app/ — edge verbs: wires, types
# app/ is the composition root — it may import services, adapters, and ports.
# The only forbidden direction is upward into cli.
[importlinter:contract:app]
name = App may not import CLI
type = forbidden
source_modules =
    scop.app
forbidden_modules =
    scop.cli


# services/ — edge verbs: calls (ports), reads (models)
# The DI rule: services may not import adapters directly.
# They call adapters through ports — import-linter enforces the boundary.
[importlinter:contract:services]
name = Services may not import adapters directly
type = forbidden
source_modules =
    scop.services
forbidden_modules =
    scop.adapters
    scop.app
    scop.cli
    scop.utils


# adapters/ — edge verbs: implements (ports), reads (models), uses (utils)
# Adapters may not reach up into services, app, or cli.
[importlinter:contract:adapters]
name = Adapters may not reach up into services, app, or CLI
type = forbidden
source_modules =
    scop.adapters
forbidden_modules =
    scop.services
    scop.app
    scop.cli


# ports/ — edge verb: types (models)
# Ports may only reference models. No other internal imports permitted.
[importlinter:contract:ports]
name = Ports may only reference models
type = forbidden
source_modules =
    scop.ports
forbidden_modules =
    scop.services
    scop.adapters
    scop.app
    scop.cli
    scop.utils


# models/ — no edge out
# models/ is the innermost layer. It depends on nothing internal.
[importlinter:contract:models]
name = Models depend on nothing internal
type = forbidden
source_modules =
    scop.models
forbidden_modules =
    scop.ports
    scop.services
    scop.adapters
    scop.app
    scop.cli
    scop.utils


# utils/ — no edge out
# utils/ is the mechanism layer. It depends on nothing internal.
# Third-party imports are permitted (enforced separately by ast-grep Rule 1).
[importlinter:contract:utils]
name = Utils depend on nothing internal
type = forbidden
source_modules =
    scop.utils
forbidden_modules =
    scop.models
    scop.ports
    scop.services
    scop.adapters
    scop.app
    scop.cli
